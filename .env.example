# ============================================================
# Glowbook — variáveis de ambiente (exemplo)
# Copie para .env e ajuste os valores.
# ============================================================

# ---------- API ----------
NODE_ENV=development
PORT=3333
DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
COOKIE_SECRET="change-me-cookie-secret"
FRONTEND_URL="http://localhost:5173"

# ---------- REDIS ----------
# Suba com: docker compose up -d   (na raiz do repo)
REDIS_URL="redis://localhost:6379"
REDIS_MODE="auto"   # auto = conecta e degrada se indisponível | off = desliga

# ---------- WEB ----------
VITE_API_URL="http://localhost:3333/api"
